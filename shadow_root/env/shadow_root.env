# Local shadow_root HTTP service.
SHADOW_PORT=8080

# Android hardware encoder profile.
SHADOW_VIDEO_BACKEND=webrtc_h264
SHADOW_VIDEO_MAX_SIZE=720
SHADOW_VIDEO_FPS=30
SHADOW_VIDEO_BITRATE=2M
SHADOW_VIDEO_IFRAME_INTERVAL_MS=1000

# Remote WebRTC gateway.
SHADOW_WEBRTC_GATEWAY_MANAGED=false
SHADOW_WEBRTC_GATEWAY_HOST=139.224.44.6
SHADOW_WEBRTC_GATEWAY_PORT=9080
SHADOW_WEBRTC_ICE_PUBLIC_IP=139.224.44.6
SHADOW_WEBRTC_ICE_UDP_PORT_MIN=30000
SHADOW_WEBRTC_ICE_UDP_PORT_MAX=30010

# Android agent -> remote gateway media transport.
SHADOW_WEBRTC_TRANSPORT=tcp_direct
SHADOW_WEBRTC_RTP_HOST=139.224.44.6
SHADOW_WEBRTC_RTP_PORT=9181
SHADOW_WEBRTC_CONTROL_PORT=9182

# Android app_process agent.
SHADOW_ANDROID_AGENT_JAR=nice_auther/shadow_root/android_agent_project/build/nice_shadow_agent.jar
